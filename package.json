{
  "name": "@omicronenergy/oscd-menu-validate",
  "description": "OpenSCD Plugin for Validating SCL files against the SCL Template Validator and XML Schema Validator",
  "license": "Apache-2.0",
  "author": "oscd-save",
  "version": "0.0.2",
  "main": "dist/oscd-menu-validate.js",
  "module": "dist/oscd-menu-validate.js",
  "exports": {
    ".": "./dist/oscd-menu-validate.js"
  },
  "scripts": {
    "analyze": "cem analyze --litelement",
    "start": "npm run build && concurrently -k -r \"tsc --watch --preserveWatchOutput\" \"wds --node-resolve\"",
    "start:bundle": "npm run bundle && concurrently -k -r \"rollup -c rollup.config.js --watch\" \"wds --open ./dist/demo/ \"",
    "build": "rimraf dist && tsc && mkdir -p dist/schema/xmlvalidate && cp node_modules/@openenergytools/xml-schema-validator/dist/xmlvalidate/xmlvalidate.js node_modules/@openenergytools/xml-schema-validator/dist/xmlvalidate/xmlvalidate.wasm dist/schema/xmlvalidate/",
    "bundle": "rimraf dist && rollup -c rollup.config.js",
    "deploy": "npm run bundle && gh-pages -d dist -b deploy",
    "pages": "gh-pages --dist 'dist'",
    "prepublish": "tsc && npm run analyze -- --exclude dist",
    "lint": "eslint --ext .ts,.html . --ignore-path .gitignore && prettier \"**/*.ts\" --check --ignore-path .gitignore",
    "format": "eslint --ext .ts,.html . --fix --ignore-path .gitignore && prettier \"**/*.ts\" --write --ignore-path .gitignore",
    "test": "npm run build && wtr --coverage --group unit",
    "test:visual": "npm run build && wtr --group visual",
    "test:update": "tsc && wtr --update-visual-baseline",
    "test:watch": "tsc && concurrently -k -r \"tsc --watch --preserveWatchOutput\" \"wtr --watch\""
  },
  "dependencies": {
    "@material/mwc-button": "^0.27.0",
    "@material/mwc-dialog": "0.27.0",
    "@material/mwc-formfield": "^0.27.0",
    "@material/mwc-icon": "^0.27.0",
    "@material/mwc-icon-button-toggle": "^0.27.0",
    "@material/mwc-list": "^0.27.0",
    "@material/mwc-snackbar": "^0.27.0",
    "@material/mwc-switch": "^0.27.0",
    "@omicronenergy/oscd-shell": "^0.0.13",
    "@open-wc/scoped-elements": "^3.0.6",
    "@webcomponents/scoped-custom-element-registry": "^0.0.10",
    "@omicronenergy/oscd-background-editv1": "^0.0.7",
    "@omicronenergy/oscd-menu-open": "^0.0.6",
    "@omicronenergy/oscd-menu-save": "^0.0.2",
    "@openenergytools/scl-template-validator": "^0.0.3",
    "@openenergytools/xml-schema-validator": "^0.0.1",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.6.6",
    "@open-wc/building-rollup": "^2.0.2",
    "@open-wc/eslint-config": "^8.0.2",
    "@open-wc/testing": "^3.1.6",
    "@openscd/open-scd-core": "0.0.2",
    "@rollup/plugin-node-resolve": "^15.0.1",
    "@rollup/plugin-typescript": "^9.0.2",
    "@types/mocha": "^10.0.10",
    "@typescript-eslint/eslint-plugin": "^5.41.0",
    "@typescript-eslint/parser": "^5.41.0",
    "@web/dev-server": "^0.1.35",
    "@web/rollup-plugin-html": "^3.1.0",
    "@web/rollup-plugin-import-meta-assets": "^2.3.3",
    "@web/test-runner": "0.20.2",
    "@web/test-runner-commands": "^0.9.0",
    "@web/test-runner-playwright": "0.11.1",
    "@web/test-runner-visual-regression": "^0.9.0",
    "concurrently": "^7.5.0",
    "deepmerge": "^4.2.2",
    "eslint": "^8.26.0",
    "eslint-config-prettier": "^8.5.0",
    "gh-pages": "^4.0.0",
    "husky": "^4.3.8",
    "lint-staged": "^13.0.3",
    "prettier": "^2.7.1",
    "rimraf": "^3.0.2",
    "rollup": "^2.79.1",
    "rollup-plugin-copy": "^3.5.0",
    "tslib": "^2.4.1",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "playwright": "1.59.1"
  },
  "customElements": "custom-elements.json",
  "eslintConfig": {
    "parser": "@typescript-eslint/parser",
    "extends": [
      "@open-wc",
      "prettier"
    ],
    "plugins": [
      "@typescript-eslint"
    ],
    "rules": {
      "no-unused-vars": "off",
      "@typescript-eslint/no-unused-vars": [
        "error"
      ],
      "import/no-unresolved": "off",
      "import/extensions": [
        "error",
        "always",
        {
          "ignorePackages": true
        }
      ]
    }
  },
  "prettier": {
    "singleQuote": true,
    "arrowParens": "avoid"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
